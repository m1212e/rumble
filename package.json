{
  "name": "@m1212e/rumble",
  "module": "./out/index.mjs",
  "version": "0.23.4",
  "type": "module",
  "repository": "https://github.com/m1212e/rumble",
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "scripts": {
    "format": "bun run lint",
    "lint": "bunx biome check --write .",
    "dev:docker": "docker compose -f ./dev.docker-compose.yml up",
    "dev:example": "bun ./example/src/main.ts",
    "dev:example:seed": "bun example/src/db/seed.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test:types": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@graphql-tools/executor-http": "^3.3.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/pluralize": "^0.0.33",
    "drizzle-kit": "^1.0.0-rc.4",
    "drizzle-orm": "^1.0.0-rc.4",
    "drizzle-seed": "^1.0.0-rc.4",
    "expect-type": "^1.4.0",
    "graphql": "^17.0.2",
    "graphql-ws": "^6.0.8",
    "lefthook": "^2.1.9",
    "pg": "^8.22.0",
    "rolldown-plugin-dts": "^0.27.1",
    "sofa-api": "^0.18.10",
    "svelte": "^5.56.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": "^4 || ^5 || ^6",
    "drizzle-orm": "^1",
    "graphql": "^16",
    "sofa-api": "^0.18",
    "graphql-ws": "^6",
    "svelte": "^5"
  },
  "peerDependenciesMeta": {
    "graphql-ws": {
      "optional": true
    },
    "sofa-api": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "dependencies": {
    "@escape.tech/graphql-armor": "^3.2.0",
    "@graphql-yoga/plugin-disable-introspection": "^2.22.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/semantic-conventions": "^1.42.0",
    "@pothos/core": "^4.13.0",
    "@pothos/plugin-drizzle": "^0.17.4",
    "@pothos/plugin-smart-subscriptions": "^4.1.4",
    "@pothos/plugin-tracing": "^1.1.2",
    "@pothos/tracing-opentelemetry": "^1.2.0",
    "@urql/core": "^6.0.3",
    "@urql/exchange-graphcache": "^9.0.1",
    "@urql/introspection": "^1.2.1",
    "devalue": "^5.8.1",
    "es-toolkit": "^1.49.0",
    "graphql-scalars": "^1.25.0",
    "graphql-yoga": "^5.21.2",
    "pluralize": "^8.0.0",
    "wonka": "^6.3.6"
  },
  "main": "./out/index.cjs",
  "types": "./out/index.d.cts",
  "exports": {
    ".": {
      "import": "./out/index.mjs",
      "require": "./out/index.cjs"
    },
    "./client": {
      "import": "./out/client.mjs",
      "require": "./out/client.cjs"
    },
    "./client/generate": {
      "import": "./out/client/generate.mjs",
      "require": "./out/client/generate.cjs"
    },
    "./package.json": "./package.json"
  },
  "inlinedDependencies": {
    "@whatwg-node/promise-helpers": "1.3.2",
    "@whatwg-node/server": "0.10.18",
    "fets": "0.8.6",
    "hotscript": "1.0.13",
    "json-schema-to-ts": "3.1.1",
    "ts-algebra": "2.0.0"
  }
}
